# DefOf classes: the engine's DefOfHelper.RebindAllDefOfs reflects over PUBLIC STATIC fields and
# matches each field's NAME to a def's TYD `name` (which carries underscores, e.g. Mod_Thing).
# So DefOf fields must be public and may contain underscores — the field-naming rules can't apply.
[**/*DefOf.cs]
dotnet_diagnostic.SA1401.severity = none # field must be private — DefOf fields are reflection-bound, must be public
dotnet_diagnostic.SA1307.severity = none # field must begin uppercase — name must byte-match the def name
dotnet_diagnostic.SA1310.severity = none # field must not contain underscore — def names use underscores
dotnet_diagnostic.SA1311.severity = none # static readonly field naming — same reason
dotnet_diagnostic.SA1600.severity = none # documented elements — DefOf fields are self-describing

# Def DEFINITION classes (a Def subclass, file named *Def.cs): the TYD/XML def loader binds
# instance fields by their PUBLIC camelCase name via reflection. Public consumers also read these
# fields directly (channelDef.defaultLevel). So they must stay public + camelCase.
[**/*Def.cs]
dotnet_diagnostic.SA1401.severity = none # field must be private — def fields are loader-bound, public API
dotnet_diagnostic.SA1307.severity = none # field must begin uppercase — TYD key binds by camelCase name
dotnet_diagnostic.SA1310.severity = none # field must not contain underscore — some def fields use them
