<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework></TargetFramework>
    <TargetFrameworks>net10.0;netstandard2.0</TargetFrameworks>
    <AssemblyName>Concord</AssemblyName>
    <RootNamespace>Concord</RootNamespace>
    <OutputPath>../../Assemblies</OutputPath>
    <GenerateDependencyFile>false</GenerateDependencyFile>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>

    <!-- Packs the ILRepack-merged Assemblies/Concord.dll (MonoMod folded in), so the
         package carries no dependency group and no raw build output. The 'Concord' id
         on nuget.org is taken by an unrelated abandoned package. -->
    <IsPackable>true</IsPackable>
    <PackageId>Concord.Runtime</PackageId>
    <Description>The Concord runtime assembly: the single merged Concord.dll a target runtime ships and loads to run patches. Mods compile against Concord.Ref; this package is for runtime integrators.</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
    <WarningsNotAsErrors>NU5128</WarningsNotAsErrors>
    <NoWarn>$(NoWarn);NETSDK1023</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath=""/>
    <None Include="../../Assemblies/net10.0/Concord.dll" Pack="true" PackagePath="lib/net10.0" Visible="false"/>
    <None Include="../../Assemblies/netstandard2.0/Concord.dll" Pack="true" PackagePath="lib/netstandard2.0" Visible="false"/>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../Concord.Detour/Concord.Detour.csproj"/>
    <ProjectReference Include="../Concord.Emit/Concord.Emit.csproj"/>
    <ProjectReference Include="../Concord.AttachedData/Concord.AttachedData.csproj"/>
    <ProjectReference Include="../Concord.Orchestration/Concord.Orchestration.csproj"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="ILRepack.Lib.MSBuild.Task" Version="2.0.45" PrivateAssets="all"/>
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <PackageReference Include="NETStandard.Library" Version="2.0.3" PrivateAssets="all"/>
  </ItemGroup>

</Project>
